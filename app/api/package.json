{
  "name": "nodejs-express-template",
  "version": "1.0.0",
  "description": "My personal template to use to accelerate project setup in Node.js/Express",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "NODE_PRESERVE_SYMLINKS=1 dotenv -e .env -- tsx watch src/index.ts",
    "start": "dotenv -e .env.production -- node dist/index.js",
    "build": "tsup",
    "commit:check": "npm run format && npm run lint && npm run test && npm run build",
    "test": "vitest run",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "format:check": "biome format . --check",
    "db:generate": "dotenv -e .env -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "db:studio": "dotenv -e .env -- drizzle-kit studio",
    "sync": "NODE_PRESERVE_SYMLINKS=1 dotenv -e .env -- tsx src/worker/sync.ts",
    "backfill:footystats": "NODE_PRESERVE_SYMLINKS=1 dotenv -e .env -- tsx src/scripts/backfill-footystats-history.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YoUnGi102/NodeJS-Express-Template.git"
  },
  "keywords": [
    "node.js",
    "typescript",
    "express",
    "template"
  ],
  "author": "YoUnGi102 (Tomáš Greš)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/YoUnGi102/NodeJS-Express-Template/issues"
  },
  "homepage": "https://github.com/YoUnGi102/NodeJS-Express-Template#readme",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.2",
    "@nrl/types": "file:../../packages/types",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "fs": "^0.0.1-security",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "tsyringe": "^4.10.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.25.51",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.15.18",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "depcheck": "^1.4.7",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.9",
    "sqlite3": "^5.1.7",
    "supertest": "^7.1.1",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-transform-paths": "^3.5.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.1"
  }
}