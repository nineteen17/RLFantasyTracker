# Domains
APP_DOMAIN=footybreakevens.com
API_DOMAIN=api.footybreakevens.com

# Images (pin by digest in production)
API_IMAGE=docker.io/yourorg/rlfantasy-api@sha256:replace_with_digest
WEB_IMAGE=docker.io/yourorg/rlfantasy-web@sha256:replace_with_digest

# TLS + DNS challenge
TRAEFIK_ACME_EMAIL=ops@footybreakevens.com
CF_DNS_API_TOKEN=replace_with_cloudflare_dns_token

# App runtime
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
JWT_ACCESS_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Optional upstream cookie auth
FOOTY_STATS_COOKIE=
FOOTY_STATS_XSRF_TOKEN=
FOOTY_STATS_USER_AGENT=
