# Required
region               = "syd1"
droplet_size         = "s-1vcpu-2gb"
ssh_key_fingerprints = ["00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00"]
admin_cidrs          = ["203.0.113.10/32"]

# Recommended security setting:
enable_cloudflare_origin_lock = true

# Keep Cloudflare ranges current from:
# https://www.cloudflare.com/ips/
cloudflare_ipv4_cidrs = [
  "173.245.48.0/20",
  "103.21.244.0/22",
  "103.22.200.0/22",
  "103.31.4.0/22",
  "141.101.64.0/18",
  "108.162.192.0/18",
  "190.93.240.0/20",
  "188.114.96.0/20",
  "197.234.240.0/22",
  "198.41.128.0/17",
  "162.158.0.0/15",
  "104.16.0.0/13",
  "104.24.0.0/14",
  "172.64.0.0/13",
  "131.0.72.0/22",
]

cloudflare_ipv6_cidrs = [
  "2400:cb00::/32",
  "2606:4700::/32",
  "2803:f800::/32",
  "2405:b500::/32",
  "2405:8100::/32",
  "2a06:98c0::/29",
  "2c0f:f248::/32",
]

# Optional tuning
project_name           = "RLFantasyTracker"
environment            = "production"
droplet_name           = "rlfantasy-prod"
droplet_image          = "ubuntu-24-04-x64"
assign_reserved_ip     = true
enable_monitoring      = true
enable_droplet_backups = false
extra_tags             = ["traefik", "docker"]

# Optional cloud-init
# user_data = file("${path.module}/cloud-init.yaml")
